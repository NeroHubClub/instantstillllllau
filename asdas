-- Freeze Trade button click
FreezeTradeButton.MouseButton1Click:Connect(function()
	AddLog("──────────", Color3.fromRGB(150, 150, 150))
	AddLog("> FREEZE ON", Color3.fromRGB(100, 255, 150))

	local freezeMessages = {
		"Scanning...", "Trade found", "Player freezed!", "Freeze lvl 1",
		"Locking...", "Player freezed!", "Items secured", "Freeze lvl 2",
		"Trade locked", "Player freezed!", "Anti-cancel on", "Freeze lvl 3",
		"Player freezed!", "Freeze max", "Transferring...", "Player freezed!",
		"Complete!", "take all brainrots!", "Done!", "Freeze Trade completed!"
	}

	for i = 1, 20 do
		task.spawn(function()
			local delay
			if i <= 8 then delay = 0.05
			elseif i <= 14 then delay = 0.08
			else delay = 0.12 end

			task.wait((i - 1) * delay)

			local color
			if freezeMessages[i] == "Player freezed!" then
				color = Color3.fromRGB(255, 100, 100)
			elseif freezeMessages[i] == "take all brainrots!" then
				color = Color3.fromRGB(255, 255, 100)
			else
				color = Color3.fromRGB(math.random(150, 255), math.random(150, 255), math.random(150, 255))
			end

			AddLog("> " .. freezeMessages[i], color)

			if i == 20 then
				task.wait(0.2)
				AddLog("──────────", Color3.fromRGB(150, 150, 150))
			end
		end)
	end
end)

-- Auto-Ready button click
AutoReadyButton.MouseButton1Click:Connect(function()
	if isAutoReadyRunning then
		isAutoReadyRunning = false
		AutoReadyButton.Text = "Auto - Ready"
		AutoReadyButton.BackgroundColor3 = Color3.fromRGB(50, 130, 255)
		AddLog("> Stopped", Color3.fromRGB(255, 100, 100))
		AddLog("──────────", Color3.fromRGB(150, 150, 150))
		return
	end
	
	isAutoReadyRunning = true
	
	AddLog("──────────", Color3.fromRGB(150, 150, 150))
	AddLog("> AUTO SEQUENCE", Color3.fromRGB(200, 120, 255))
	
	-- First 5 seconds: Countdown
	AddLog("> Ready in 5...", Color3.fromRGB(255, 255, 100))
	task.wait(1)
	AddLog("> Ready in 4...", Color3.fromRGB(255, 255, 100))
	task.wait(1)
	AddLog("> Ready in 3...", Color3.fromRGB(255, 255, 100))
	task.wait(1)
	AddLog("> Ready in 2...", Color3.fromRGB(255, 255, 100))
	task.wait(1)
	AddLog("> Ready in 1...", Color3.fromRGB(255, 255, 100))
	task.wait(1)
	AddLog("> GO!", Color3.fromRGB(100, 255, 150))
	
	if not isAutoReadyRunning then return end
	
	-- Next 5 seconds: Rapid auto-ready messages
	AddLog("> AUTO-READY", Color3.fromRGB(200, 120, 255))
	
	local startTime = tick()
	local msgIndex = 1
	while tick() - startTime < 5 and isAutoReadyRunning do
		local color = Color3.fromRGB(
			math.random(150, 255),
			math.random(150, 255),
			math.random(150, 255)
		)
		AddLog("> " .. autoReadyRapidMessages[((msgIndex - 1) % #autoReadyRapidMessages) + 1], color)
		msgIndex = msgIndex + 1
		task.wait(0.2)
	end
	
	if not isAutoReadyRunning then return end
	
	-- Next 5 seconds: Auto-accept messages
	AddLog("> AUTO-ACCEPT", Color3.fromRGB(100, 255, 150))
	
	startTime = tick()
	msgIndex = 1
	while tick() - startTime < 5 and isAutoReadyRunning do
		local color = Color3.fromRGB(
			math.random(180, 255),
			math.random(100, 200),
			math.random(180, 255)
		)
		AddLog("> " .. autoAcceptMessages[((msgIndex - 1) % #autoAcceptMessages) + 1], color)
		msgIndex = msgIndex + 1
		task.wait(0.2)
	end
	
	if not isAutoReadyRunning then return end
	
	-- Final message
	AddLog("──────────", Color3.fromRGB(150, 150, 150))
	AddLog("> Processing...!", Color3.fromRGB(255, 255, 100))
	AddLog("> Please wait till gifted.", Color3.fromRGB(100, 255, 150))
	AddLog("──────────", Color3.fromRGB(150, 150, 150))
	
	-- Reset
	task.wait(2)
	if isAutoReadyRunning then
		isAutoReadyRunning = false
		AutoReadyButton.Text = "Auto - Ready"
		AutoReadyButton.BackgroundColor3 = Color3.fromRGB(50, 130, 255)
	end
end)

